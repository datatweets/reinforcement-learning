# =============================================================
# Reinforcement Learning Module — .gitignore
# =============================================================

# -----------------------------------------------
# Jupyter Notebook
# -----------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/
*.ipynb_meta

# -----------------------------------------------
# Python
# -----------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.pyo
*.so

# -----------------------------------------------
# Virtual Environments
# -----------------------------------------------
.venv/
venv/
env/
.env/
ENV/
.conda/

# -----------------------------------------------
# Distribution / Build
# -----------------------------------------------
dist/
build/
*.egg-info/
*.egg
.eggs/

# -----------------------------------------------
# Package managers
# -----------------------------------------------
pip-log.txt
pip-delete-this-directory.txt
.pip/

# -----------------------------------------------
# Testing & Coverage
# -----------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/

# -----------------------------------------------
# Logs & Temporary files
# -----------------------------------------------
*.log
*.tmp
*.bak
*.swp
*.swo

# -----------------------------------------------
# macOS
# -----------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*

# -----------------------------------------------
# Windows
# -----------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------
# IDEs & Editors
# -----------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.kate-swp

# -----------------------------------------------
# Data & Model files (can be large)
# -----------------------------------------------
*.h5
*.hdf5
*.pkl
*.pickle
*.npy
*.npz
saved_models/
checkpoints/
runs/
wandb/

# -----------------------------------------------
# Microsoft Office temp files
# -----------------------------------------------
~$*.docx
~$*.xlsx
~$*.pptx

# -----------------------------------------------
# Backup content (local reference only)
# -----------------------------------------------
backup_content/
